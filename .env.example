# Database
DATABASE_URL=postgresql://user:pass@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:pass@host:5432/postgres
PG_BOSS_URL=postgresql://user:pass@host:5432/postgres

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...

# Auth
JWT_SECRET=minimum-32-character-random-string
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# URLs — for local dev, both must point at localhost or Google OAuth will bounce you
# to production (Render callback → production FRONTEND_URL on Vercel).
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000

# Email (SMTP) — optional; set EMAIL_ENABLED=true when ready
EMAIL_ENABLED=false
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=your-api-key
# SMTP_FROM=ScoutIQ <hello@scoutiq.com>

# App config
PORT=4000
SCORE_THRESHOLD=50
SITE_EXPIRY_DAYS=7
# Set to false to disable preview expiry entirely (no cleanup, no reminder emails)
SITE_EXPIRY_ENABLED=true
NODE_ENV=development

# Site templates — use localhost template servers during dev
USE_LOCAL_TEMPLATES=true
