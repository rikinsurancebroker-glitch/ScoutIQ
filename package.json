{
  "name": "scoutiq-backend",
  "version": "1.0.0",
  "description": "ScoutIQ AI-powered B2B SaaS backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:all": "concurrently -n api,web -c blue,magenta \"npm run dev\" \"npm run dev:frontend\"",
    "dev:full": "concurrently -n api,web,workers -c blue,magenta,yellow \"npm run dev\" \"npm run dev:frontend\" \"npm run workers\"",
    "workers": "ts-node src/queues/workerServer.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:workers": "node dist/queues/workerServer.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "fix:local-urls": "node scripts/fix-local-template-urls.js",
    "fix:production-urls": "node scripts/fix-production-template-urls.js",
    "check:pipeline": "node scripts/check-pipeline.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.45.4",
    "axios": "^1.7.7",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.15",
    "openai": "^4.68.4",
    "papaparse": "^5.4.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg-boss": "^10.4.2",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.8.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.16",
    "@types/papaparse": "^5.3.14",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/qrcode": "^1.5.5",
    "concurrently": "^9.2.3",
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
